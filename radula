rad_behave_bootstrap_cross_img() {
  # Remove `-S` from rsync (for sudo and IO error)
  RSYNC='rsync -vaHAXx'

  $RM $1
  qemu-img create -f raw $1 $2
  # Write mbr.bin (from SYSLINUX) to the first 440 bytes of our image
  dd if=other/mbr.bin of=$1 conv=notrunc bs=440 count=1

  parted -s $1 mklabel msdos
  # Default to ext4 which complies with the generated fstab
  parted -s -a none $1 mkpart primary ext4 0 $2
  parted -s -a none $1 set 1 boot on

  losetup -D
  losetup $3 $1

  # Notify the kernel about the new partition
  partx -a $3
  mkfs.ext4 $(printf $3)p1

  $MKDIR $4

  mount $(printf $3)p1 $4

  $RM $4/lost+found

  $RSYNC $CRSD/ $4 || rad_close 'Please bootstrap a cross compiled glaucus system first!'

  $MKDIR $4/boot/extlinux
  $RSYNC other/extlinux.conf.$init $4/boot/extlinux/extlinux.conf

  $CHOWN -R 0:0 $4

  extlinux --install $4/boot/extlinux

  # Clean up
  $UMOUNT $4
  partx -d $3
  losetup -d $3

  $RSYNC $1 $BAKD
}

rad_behave_bootstrap_cross_prepare() {
  $RSYNC $BAKD/cross $GLAD --delete
  $RSYNC $BAKD/toolchain $GLAD --delete

  $RM $XBLD
  $MKDIR $XBLD

  $MKDIR $XSRC
}

rad_behave_bootstrap_cross_strip() {
  find $CRSD/etc -type d -empty -delete

  find $CRSD/usr -name *.a -type f -exec strip -gv {} \;
  find $CRSD/usr \( -name *.so* -a ! -name *dbg \) -type f -exec strip \
    --strip-unneeded -v {} \;
  find $CRSD/usr -type f -exec strip -sv {} \;
  find $CRSD/usr -name *.la -delete

  $RM $CRSD/usr/lib/charset.alias
}

rad_behave_bootstrap_cross_variables() {
  export XTMP=$TMPD/cross

  export XBLD=$XTMP/builds
  export XSRC=$XTMP/src

  # NATIVECC and NATIVECXX were superceded by HOSTCC and HOSTCXX.
  #
  # HOSTCC and HOSTCXX are optional (used in netbsd-curses for nbperf and tic).
  export HOSTCC=gcc
  export HOSTCXX=g++

  # Don't set CROSS_COMPILE for the toolchain stage (only musl requires it)
  export CROSS_COMPILE=$TGT-

  export AR=$TGT-gcc-ar
  export AS=$TGT-as
  export CC=$TGT-gcc
  export CPP="$TGT-gcc -E"
  export CXX=$TGT-g++
  export LD=$TGT-ld.bfd
  export NM=$TGT-gcc-nm
  export OBJCOPY=$TGT-objcopy
  export OBJDUMP=$TGT-objdump
  export RANLIB=$TGT-gcc-ranlib
  export READELF=$TGT-readelf
