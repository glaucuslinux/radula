# Action functions

# Functions without the _bootstrap_ are used both for regular cerata mode and
# for the bootstrap mode. Only functions that are used for bootstrap have the
# _bootstrap_ keyword added.

# The rad_close statement is directly used here, instead of adding it following
# the call of the function. This is done because this function is used twice
# (once in fetch and once in check), which is unlike fetch which is only used in
# check so its rad_close comes after its call.
rad_behave_verify() {
  if [ $ver != git ]; then
    printf "$sum $SRCD/$nom/$(basename $url)" | sha512sum -c > /dev/null || rad_close "ceras $nom verify exited with status $?"
  else
    return 0
  fi
}

rad_behave_fetch() {
  if [ $ver = git ]; then
    git clone -q $url $SRCD/$nom
  else
    curl -Lso $SRCD/$nom/$(basename $url) $url

    rad_behave_verify

    tar xf $SRCD/$nom/$(basename $url) -C $SRCD/$nom
  fi
}

rad_behave_check() {
  . $CERD/$1/ceras

  if [ ! -d $SRCD/$nom ]; then
    $MKDIR $SRCD/$nom

    rad_behave_fetch || rad_close "ceras $nom fetch exited with status $?"
  else
    rad_behave_verify
  fi
}

# The main function responsible for building cerata. Logging will be implemented
# in the future in a way different from the previous logging mechanism.
rad_behave_construct() {
  . $CERD/$2/ceras
  . $CERD/$nom/$1.ceras

  prepare || rad_close "ceras $nom prepare exited with satus $?"
  configure || rad_close "ceras $nom configure exited with satus $?"
  build || rad_close "ceras $nom build exited with satus $?"
  install || rad_close "ceras $nom install exited with satus $?"
}

# A special version of rad_behave_construct that's tailored for the
# production/bootstrapping of the final cross compiled system. The only
# difference between construct and envenomate is that the latter creates a sac
# and a venom directory to store the installed files of a ceras that has arleady
# been built (The sac is technically the DESTDIR while venom stores the packaged
# tarball of sac with a sum file of sha512sums).
#
# This is done to keep track of the installed files.
#
# Envenomate also copies the contents of the sac to the target cross compiled
# system directory.
rad_behave_envenomate() {
  $MKDIR $XCER/$1/sac
  $MKDIR $XCER/$1/venom

  rad_behave_construct cross $1

  $RSYNC $XCER/$1/sac/ $CRSD
}

# The GNU function, which basically copies any of config.guess, config.sub or
# config.rpath from a unified location where the binutils ceras is kept to the
# requested destination.
rad_behave_gnu() {
  $RSYNC $CERD/binutils/config.$1 $2
}

# This might be moved to bootstrap_initialize since it must be run only once
# before anything starts (since it has sources I doubt if clean will remove
# those but we still have to find out...)
rad_behave_initialize() {
  $MKDIR $BAKD
  $MKDIR $SRCD
  $MKDIR $TLCD

  $MKDIR $LOGD/chroot
  $MKDIR $LOGD/cross
  $MKDIR $LOGD/toolchain

  $MKDIR $TMPD/chroot/builds
  $MKDIR $TMPD/chroot/sources

  $MKDIR $TMPD/cross/builds
  $MKDIR $TMPD/cross/cerata
  $MKDIR $TMPD/cross/sources

  $MKDIR $TMPD/toolchain/sources
  $MKDIR $TMPD/toolchain/builds
}

rad_behave_patch() {
  if [ $sleep -eq 0 ]; then
    patch -p$1 -i $CERD/$2/patches/$3/$4.patch
  else
    patch -p$1 -si $CERD/$2/patches/$3/$4.patch
  fi
}

