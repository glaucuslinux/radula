set -e
umask 022

# Define the default variables
behavior=envenomate
sleep=0

# Standard output function
rad_signal() {
  [ $sleep = 0 ] && printf "\033[0;34m~~\033[0m $1\n" || printf "$1\n"
}

# Standard error function
rad_die() {
  [ $sleep = 0 ] && printf "\033[0;31m~~\033[0m $1\n" || printf "$1\n"
  exit 1
}

# Information functions
rad_license() {
  rad_signal 'Copyright (c) 2018-2020, Firas Khalil Khana'
  rad_signal 'Distributed under the terms of the ISC License'
}

rad_version() {
  rad_license

  rad_signal
  rad_signal "$0 version 0.1"
}

# require will be moved to behave bootstrap options
rad_help() {
  rad_version

  rad_signal
  rad_signal 'Usage:'
  rad_signal "\t$0 (Flags)"
  rad_signal
  rad_signal 'Flags:'
  rad_signal '\tb, -b, --behave \tPerform any of the following behaviors:'
  rad_signal '\t                \tbootstrap, envenomate (default)'
  rad_signal
  rad_signal '\tg, -g, --genome \tDisplay current genome'
  rad_signal '\th, -h, --help   \tDisplay this help message'
  rad_signal '\tl, -l, --list   \tList available genomes and species'
  rad_signal '\tq, -q, --quiet  \tDo not prefix output with ~~'
  rad_signal '\t       --sleep  \tSame as --quiet'
  rad_signal
  rad_signal '\tr, -r, --require\tDisplay bootstrap requirements'
  rad_signal '\ts, -s, --species\tDisplay current species'
  rad_signal '\tv, -v, --version\tDisplay version number'
}

rad_behave_help() {
  rad_version

  rad_signal
  rad_signal 'Usage:'
  rad_signal "\t$0 b (Options)"
  rad_signal
  rad_signal 'Options:'
  rad_signal "\tb, bootstrap \tPerform bootstrap behavior"
  rad_signal "\te, envenomate\tPerform envenomate behavior (default)"
}

rad_behave_bootstrap_help() {
  rad_version

  rad_signal
  rad_signal 'Usage:'
  rad_signal "\t$0 b b (Options)"
  rad_signal
  rad_signal 'Options:'
  rad_signal "\tc, chroot   \tBootstrap a chroot environment"
  rad_signal "\tt, toolchain\tBootstrap a cross-compiler toolchain"
  rad_signal "\tx, cross    \tBootstrap a cross-compiled glaucus system (default)"
}

rad_behave_envenomate_help() {
  rad_version

  rad_signal
  rad_signal 'Usage:'
  rad_signal "\t$0 b e (Options) [Cerata]"
  rad_signal
  rad_signal 'Options:'
  rad_signal "\tn, nom, name               \tDisplay ceras's name"
  rad_signal "\tv, ver, version            \tDisplay ceras's version"
  rad_signal "\tu, url, source             \tDisplay ceras's source"
  rad_signal "\ts, sum, checksum, sha512sum\tDisplay ceras's sha512sum"
  rad_signal "\tl, lic, license, licenses  \tDisplay ceras's license(s)"
}

# Action functions
rad_require() {
  rad_signal "bash:     \t$(bash --version | sed 1q | cut -d' ' -f4)"
  rad_signal "bc:       \t$(bc --version | sed 1q | cut -d' ' -f2)"
  rad_signal "binutils: \t$(ld --version | sed 1q | cut -d' ' -f4)"
  rad_signal "bison:    \t$(bison --version | sed 1q | cut -d' ' -f4)"
  rad_signal "bzip2:    \t$(bzip2 --version 2>&1 < /dev/null | sed 1q | cut -d' ' -f8 | sed s/,//)"
  rad_signal "ccache:   \t$(ccache --version | sed 1q | cut -d' ' -f3)"
  rad_signal "coreutils:\t$(ls --version | sed 1q | cut -d' ' -f4)"
  rad_signal "diffutils:\t$(diff --version | sed 1q | cut -d' ' -f4)"
  rad_signal "findutils:\t$(find --version | sed 1q | cut -d' ' -f4)"
  rad_signal "g++:      \t$(g++ --version | sed 1q | cut -d' ' -f3)"
  rad_signal "gawk:     \t$(gawk --version | sed 1q | cut -d' ' -f3 | sed s/,//)"
  rad_signal "gcc:      \t$(gcc --version | sed 1q | cut -d' ' -f3)"
  rad_signal "git:      \t$(git --version | cut -d' ' -f3)"
  rad_signal "glibc:    \t$(/lib/libc.so.6 | sed 1q | cut -d' ' -f9 | sed s/\.$//)"
  rad_signal "grep:     \t$(grep --version | sed 1q | cut -d' ' -f4)"
  rad_signal "gzip:     \t$(gzip --version | sed 1q | cut -d' ' -f2)"
  rad_signal "linux:    \t$(uname -r)"
  rad_signal "lzip:     \t$(lzip --version | sed 1q | cut -d' ' -f2)"
  rad_signal "m4:       \t$(m4 --version | sed 1q | cut -d' ' -f4)"
  rad_signal "make:     \t$(make --version | sed 1q | cut -d' ' -f3)"
  rad_signal "patch:    \t$(patch --version | sed 1q | cut -d' ' -f3)"
  rad_signal "perl:     \t$(perl -V:version | cut -d"'" -f2)"
  rad_signal "rsync:    \t$(rsync --version | sed 1q | cut -d' ' -f4)"
  rad_signal "sed:      \t$(sed --version | sed 1q | cut -d' ' -f4)"
  rad_signal "tar:      \t$(tar --version | sed 1q | cut -d' ' -f4)"
  rad_signal "texinfo:  \t$(makeinfo --version | sed 1q | cut -d' ' -f4)"
  rad_signal "xz:       \t$(xz --version | sed 1q | cut -d' ' -f4)"
  rad_signal "zstd:     \t$(zstd --version | cut -d' ' -f7 | sed 's/,$//')"
}

rad_bootstrap() {
  :
}

# Source the configuration file in /etc/radula.conf
# Will soon be replaced with /etc/radula.conf (No forward slash for testing atm)
. etc/radula.conf

# Catch the quiet signal wherever it was
case "$@" in
  *q* | *-q* | *--quiet* | *--sleep*)
    sleep=1
    ;;
esac

# Our basic and portable argument parser
# Sets basic behavior variables and prints information only
# ./rad l q [g, s] doesn't work yet
while [ $# -ge 0 ]; do
  case $1 in
    b | -b | --behave)
      case $2 in
        b | bootstrap)
          case $3 in
            t | toolchain)
              rad_signal 'Setting default behavior to bootstrap...'
              rad_signal

              behavior=bootstrap

              rad_signal 'Checking if host system has all required packages...'
              rad_signal

              rad_require

              rad_signal
              rad_signal 'Bootstrapping an x86-64 cross-compiler toolchain targetting musl libc...'
              ;;
            *)
              rad_behave_bootstrap_help
              exit 1
              ;;
          esac
          ;;
        e | envenomate)
          case $3 in
            l | lic | license | licenses)
              ;;
            n | nom | name)
              ;;
            s | sum | checksum | sha512sum)
              ;;
            u | url | source)
              ;;
            v | ver | version)
              ;;
            '' | *)
              rad_behave_envenomate_help
              exit 1
              ;;
          esac
          ;;
        *)
          rad_behave_help
          exit 1
          ;;
      esac
      exit 0
      ;;
    bb | -bb)
      shift
      $0 b b $@
      exit 0
      ;;
    be | -be)
      shift
      $0 b e $@
      exit 0
      ;;
    g | -g | --genome)
      rad_signal $genome
      exit 0
      ;;
    h | -h | --help)
      rad_help
      exit 0
      ;;
    l | -l | --list)
      case $2 in
        '')
          ./$0 l g

          rad_signal

          ./$0 l s
          ;;
        g | genome)
          rad_signal 'Genomes:'
          rad_signal '\taarch64'
          rad_signal '\tarmv6zk'
          rad_signal '\ti686'
          rad_signal '\tpowerpc'
          rad_signal '\tpowerpc64'
          rad_signal '\tpowerpc64le'
          rad_signal '\triscv64'
          rad_signal '\tx86-64 (default)'
          ;;
        s | species)
          rad_signal 'Species:'
          rad_signal '\talbino'
          rad_signal '\tatlanticus (default)'
          rad_signal '\tbennettae'
          rad_signal '\tmarginatus'
          rad_signal '\tthompsoni'
          ;;
        *)
          rad_die 'Valid list options are: g, genome, s and species'
      esac

      exit 0
      ;;
    q | -q | --quiet | --sleep)
      sleep=1
      ;;
    r | -r | --require)
      rad_require
      exit 0
      ;;
    s | -s | --species)
      rad_signal $species
      exit 0
      ;;
    v | -v | --version)
      rad_version
      exit 0
      ;;
    '' | *)
      rad_help
      exit 1
      ;;
  esac

  shift
done
