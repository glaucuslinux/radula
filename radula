# Should run when bootstrapping fails or is aborted (and if requested). The list
# of directories below needs to be updated to fit the new location of the
# system.
rad_behave_bootstrap_clean() {
  $UMOUNT $GLAD/dev
  $UMOUNT $GLAD/proc
