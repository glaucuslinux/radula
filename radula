#
# Options Parser
#

while [ $# -ge 0 ]; do
  case $1 in
    '')
      radula_help
      exit 1
      ;;
    b | -b | --behave)
      case $2 in
        b | bootstrap)
          case $3 in
            c | clean)
              radula_behave_bootstrap_variables

              radula_behave_bootstrap_toolchain_variables

              radula_behave_bootstrap_cross_variables

              radula_behave_bootstrap_clean

              radula_open 'clean complete'
              ;;
            d | distclean)
              radula_behave_bootstrap_variables

              radula_behave_bootstrap_toolchain_variables

              radula_behave_bootstrap_cross_variables

              radula_behave_bootstrap_distclean

              radula_open 'distclean complete'
              ;;
            h | -h | --help)
              radula_behave_bootstrap_help
              ;;
            i | img | image)
              if [ $(id -u) -eq 0 ]; then
                radula_behave_bootstrap_variables

                modprobe loop

                radula_behave_bootstrap_cross_img $GLAD/glaucus.img 128M $(losetup -f) /mnt/glaucus

                radula_open 'img complete'
              else
                radula_close 'Please run this script as root!'
              fi
              ;;
            l | list)
              radula_version

              radula_open

              radula_behave_bootstrap_list
              ;;
            r | require)
              radula_open 'Checking if host has all required packages...'
              radula_open

              radula_behave_bootstrap_require
              ;;
            s | release)
              radula_behave_bootstrap_variables

              radula_behave_bootstrap_toolchain_release /tmp/toolchain

              radula_open 'release complete'
              ;;
            t | toolchain)
              $0 b b r

              radula_open
              radula_open "Bootstrapping the $genome cross-compiler toolchain targetting musl libc..."

              radula_behave_bootstrap_variables

              # Only for the toolchain as we're relying on the host's ccache
              [ $ccache = yes ] && radula_behave_ccache_variables $CCCH

              radula_behave_bootstrap_initialize

              radula_behave_bootstrap_clean

              # No radula_behave_bootstrap_flags optimizations for the toolchain
              radula_behave_bootstrap_arch_variables

              radula_behave_bootstrap toolchain || {
                radula_close "Failed to boostrap an $genome cross-compiler toolchain targetting musl libc."
              }

              radula_behave_bootstrap_toolchain_backup

              radula_open
              radula_open "Successfully bootstrapped an $genome cross-compiler toolchain targetting musl libc!"
              ;;
            x | cross)
              $0 b b r

              radula_open
              radula_open "Bootstrapping the $genome cross-compiled glaucus $species system..."

              radula_behave_bootstrap_variables

              radula_behave_pkg_config_variables $CRSD

              radula_behave_bootstrap_arch_variables
              radula_behave_bootstrap_flags_variables

              radula_behave_bootstrap cross || {
                radula_close "Failed to boostrap an $genome cross-compiled glaucus $species system."
              }

              radula_behave_bootstrap_cross_strip

              radula_open
              radula_open "Successfully bootstrapped an $genome cross-compiled glaucus $species system!"
              ;;
            *)
              radula_behave_bootstrap_help
              exit 1
              ;;
          esac
          ;;
        e | envenomate)
          case $3 in
            h | help)
              radula_behave_envenomate_help
              exit 0
              ;;
            *)
              radula_behave_envenomate_help
              exit 1
              ;;
          esac
          ;;
        h | -h | --help)
          radula_behave_help
          exit 0
          ;;
        i | binary)
          case $3 in
            h | help)
              radula_behave_binary_help
              exit 0
              ;;
            *)
              radula_behave_binary_help
              exit 1
              ;;
          esac
          ;;
        *)
          radula_behave_help
          exit 1
          ;;
      esac
      exit 0
      ;;
    c | -c | --ceras)
      # This will be removed in the future (only here to test `radula -c`
      # outside of glaucus)
      CERD=${CERD-../cerata}

      # Don't check for the directory $CERD/$4 alone because when $4 is
      # empty it'll resolve to $CERD which does exist and will cause radula
      # to fail.
      if [ -f $CERD/$3/ceras ]; then
        . $CERD/$3/ceras

        case $2 in
          n | nom | name)
            radula_open "Name:        \t$nom"
            ;;
          v | ver | version)
            radula_open "Version:     \t$ver"
            ;;
          u | url | source)
            radula_open "Source:      \t$url"
            ;;
          s | sum | checksum | sha512sum)
            radula_open "sha512sum:   \t$sum"
            ;;
          y | cys | cyst | cysts)
            cys_len=$(printf "$cys" | wc -w)
            if [ $cys_len -gt 1 ]; then
              radula_open "Cysts:       \t$(printf "$cys" | sed 's/ /, /g')"
            elif [ $cys_len -eq 1 ]; then
              radula_open "Cyst:        \t$cys"
            else
              radula_open 'Cysts:       \t--'
            fi
            ;;
          c | cnt | concentrate | concentrates)
            cnt_len=$(printf "$cnt" | wc -w)
            if [ $cnt_len -gt 1 ]; then
              radula_open "Concentrates:\t$(printf "$cnt" | sed 's/ /, /g')"
            elif [ $cnt_len -eq 1 ]; then
              radula_open "Concentrate: \t$cnt"
            else
              radula_open 'Concentrates:\t--'
            fi
            ;;
          l | lic | license | licenses)
            lic_len=$(printf "$lic" | wc -w)
            if [ $lic_len -gt 1 ]; then
              radula_open "Licenses:    \t$(printf "$lic" | tr '\n' ' ' | sed 's/ /, /g')"
            elif [ $lic_len -eq 1 ]; then
              radula_open "License:     \t$lic"
            else
              radula_open 'Licenses:    \t--'
            fi
            ;;
          *)
            radula_ceras_help
            exit 1
            ;;
        esac

      elif [ ! -z $2 ] && [ -d $CERD/$2 ]; then
        . $CERD/$2/ceras

        for i in n v u s y c l; do
          $0 c $i $2
        done
      else
        radula_ceras_help
        case $2 in
          h | -h | --help)
            exit 0
            ;;
        esac
        exit 1
      fi
      exit 0
      ;;
    g | -g | --genome)
      radula_open $genome
      exit 0
      ;;
    h | -h | --help)
      radula_help
      exit 0
      ;;
    s | -s | --species)
      radula_open $species
      exit 0
      ;;
    v | -v | --version)
      radula_version
      exit 0
      ;;
  esac

  shift
done
