rad_behave_bootstrap_toolchain_construct() {
  rad_behave_construct toolchain musl-headers
  rad_behave_construct toolchain binutils
  rad_behave_construct toolchain gcc
  rad_behave_construct toolchain musl
  rad_behave_construct toolchain libgcc
  rad_behave_construct toolchain libstdc++-v3

  case $species in
    atlanticus | performance | albino | libre)
      rad_behave_construct toolchain libgomp
      ;;
  esac
}

rad_behave_bootstrap_toolchain_prepare() {
  $MKDIR $CRSD

  $MKDIR $TBLD

  $MKDIR $TSRC

  $MKDIR $TLCD
}

rad_behave_bootstrap_toolchain_release() {
  $MKDIR $1

  $RSYNC $BAKD/cross $1 --delete
  $RSYNC $BAKD/toolchain $1 --delete

  $RM $1/cross/lib64
  $RM $1/cross/usr/lib64
  $RM $1/toolchain/lib64

  find $1 -name "*.la" -delete

  strip -gv $1/cross/usr/lib/* || true
  strip -gv $1/toolchain/lib/* || true

  strip --strip-unneeded -v $1/cross/usr/bin/* || true
  strip --strip-unneeded -v $1/toolchain/bin/* || true

  $RM $1/toolchain/share/info
  $RM $1/toolchain/share/man

  cd $1
  tar -cvf $GLAD/toolchain-$(date +%d%m%Y).tar.zst -I 'zstd -22 --ultra --long=31 -T0' .
}

rad_behave_bootstrap_toolchain_variables() {
  export TTMP=$TMPD/toolchain

  export TSRC=$TTMP/src
