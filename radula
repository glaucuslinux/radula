#
# Common Behavior Variable Functions
#

# For custom ccache directories (or if host was neither Arch nor Fedora, the
# user has to specify them in /etc/radula.conf using the `CCCH` variable (along
# with ccache=yes beforehand).
radula_behave_ccache_variables() {
  CCCH=${1:-/usr/lib/ccache/bin:/usr/lib64/ccache}
  export PATH=$CCCH:$PATH
}

radula_behave_pkg_config_variables() {
  # pkgconf and pkg-config don't respect the provided sysroot (it doesn't get
  # automatically prefixed to PATH and LIBDIR)
  export PKG_CONFIG_PATH=$1/usr/lib/pkgconfig
  export PKG_CONFIG_LIBDIR=$1/usr/lib/pkgconfig
  # The trailing forward slash is important (envenomate on a glaucus system)
  export PKG_CONFIG_SYSROOT_DIR=$1/
  export PKG_CONFIG_SYSTEM_INCLUDE_PATH=$1/usr/include
  export PKG_CONFIG_SYSTEM_LIBRARY_PATH=$1/usr/lib
}

# teeth are radula's tools
radula_behave_teeth_variables() {
  export AUTORECONF='autoreconf -fvis'
  export CHMOD='chmod -Rv'
  export CHOWN='chown -Rv'
  export LN='ln -fnsv'
  export MAKE=make

  if [ $parallel = yes ]; then
    # Don't use anything higher than `nproc + 1` or `nproc * 1.5` (such as
    # `-j` alone) or you'll risk having your host system freeze.
    export MAKEFLAGS="-j$(printf '%b' "$(nproc) * 1.5 / 1\n" | bc) V=1"
  else
    export MAKEFLAGS='-j1 V=1'
  fi

  # Full path to not overlap with the install() function in .ceras files
  export MKDIR='/usr/bin/install -dv'
  export MV='mv -v'
  export RM='rm -frv'
  export RSYNC='rsync -vaHAXSx'
  export UMOUNT='umount -fqRv'
}

#
# Common Behavior Action Functions
#

radula_behave_check() {
  . $CERD/$1/ceras

  if [ ! -d $SRCD/$nom ]; then
    radula_behave_fetch $(basename $url) || radula_close "ceras $nom: fetch exited with status $?"
  # In the case of a directory existing in $SRCD, and only if it's not a git
  # repository, then verify the tarball inside (if the tarball was previously
  # extracted, then verifying it won't matter much because the extracted
  # contents could've been tampered with (which is extremely unlikely) , and
  # this would require a reextraction in all cases which would slow down build
  # times by a bit (and not by a whole much because we're using zstd). The only
  # benefit that might come from reverifying an extracted tarball is this would
  # be if the tarball was already broken, but then again it was verified before
  # so how could that happen?
  elif [ $ver != git ]; then
    radula_behave_verify $(basename $url) || radula_close "ceras $nom: verify exited with status $?"
  fi
}

radula_behave_construct() {
  . $CERD/$2/ceras
  . $CERD/$nom/$1.ceras

  radula_open
  radula_open "$nom $ver"
  radula_open 33 \< prepare

  radula_behave_construct_stage_function $1 prepare || radula_close "ceras $nom: prepare exited with status $?"

  radula_open 35 ! configure

  radula_behave_construct_stage_function $1 configure || radula_close "ceras $nom: configure exited with status $?"

  radula_open 34 \* build

  radula_behave_construct_stage_function $1 build || radula_close "ceras $nom: build exited with status $?"

  if [ check = yes ]; then
    radula_open 36 ? check

    radula_behave_construct_stage_function $1 check || radula_close "ceras $nom: check exited with status $?"
  fi

  radula_open 32 \> install

  radula_behave_construct_stage_function $1 install || radula_close "ceras $nom: install exited with status $?"
}

radula_behave_construct_stage_function() {
  $MKDIR $LOGD/$1/$nom/$2 > /dev/null
  $2 > $LOGD/$1/$nom/$2/out.log 2> $LOGD/$1/$nom/$2/err.log || \
    tail $LOGD/$1/$nom/$2/out.log $LOGD/$1/$nom/$2/err.log | sed -e \
    "s/^/$(printf '\033[0;31m-- ')/" -e "s/$/$(printf '\033[0m')/"
}

radula_behave_fetch() {
  if [ $ver = git ]; then
    git clone $url $SRCD/$nom
    git -C $SRCD/$nom checkout $cmt
  else
    $MKDIR $SRCD/$nom > /dev/null

    curl -Lo $SRCD/$nom/$1 $url

    radula_behave_verify $1 || radula_close "ceras $nom: verify exited with status $?"

    tar xvf $SRCD/$nom/$1 -C $SRCD/$nom > /dev/null
  fi
}

radula_behave_gnu() {
  $RSYNC $CERD/binutils/config.$1 $2
}

radula_behave_patch() {
  patch -p$1 -i $CERD/$2/patches/$3/$4.patch
}

radula_behave_verify() {
  printf "%s" "$sum $SRCD/$nom/$1" | sha512sum -c > /dev/null
}

#
# Bootstrap Behavior Functions
#

radula_behave_bootstrap() {
  radula_behave_bootstrap_${1}_variables
  radula_behave_bootstrap_${1}_check
  radula_behave_bootstrap_${1}_prepare

  radula_behave_bootstrap_${1}_construct
}

# Architecture related variables explained (for radula_behave_bootstrap_arch):
#
# ARCH stands for the technically correct architecture (except for ones with a
# dash in them '-', then they get turned to underscores '_').
#
# CARCH stands for Cerata ARCH, which means options/flags that are related to a
# certain architecture and are passed in that ceras's configure function mostly
# (this includes all cerata with the exception of `gcc` as that has its own
# variable GCARCH). CARCH is mostly (if not always) equal to the values of
# -march/-mtune.
#
# FARCH stands for Flags ARCH, which means options/flags that are related to a
# certain architecture and are passed in radula_behave_bootstrap_flags. The
# order in which the flags in FARCH are in is as mentioned in GCC's onlinedocs.
#
# GCARCH stands for Gcc Configuration ARCH, which means options/flags that are
# related to a certain architecture and are passed the `gcc` ceras configure
# function. The order of the flags in GCARCH is as mentioned in GCC's configure
# doc (https://gcc.gnu.org/install/configure.html).
#
# GPARCH stands for Gcc Patch ARCH, which refers to the architecture of the
# pure64 patch by glaucus applied to the `gcc` sources in the prepare function.
#
# MARCH stands for Musl ARCH, which refers to the closest architecture
# recognized by `musl` (located in the `musl/arch` directory).
#
# LARCH stands for Linux ARCH, which refers to the closest architecture
# recognized by `linux` (located in the `linux/arch` directory).
#
# LCARCH stands for Linux Configuration ARCH, which refers to the closest device
# with a similar architecture that's used to configure the kernel sources (based
# on what's available in `linux/arch/$genome/configs`).
#
# LIARCH stands for Linux Image ARCH, which refers to the directory where
# `linux` stores its image file after it has been built.
radula_behave_bootstrap_arch_variables() {
  case $genome in
    aarch64 | armv8-a | arm64)
      export ARCH=aarch64

      export CARCH=--with-gcc-arch=armv8-a

      export FARCH='-mabi=lp64 -mfix-cortex-a53-835769 -mfix-cortex-a53-843419 -march=armv8-a -mtune=generic'

      export GCARCH='--with-arch=armv8-a --with-abi=lp64 --enable-fix-cortex-a53-835769 --enable-fix-cortex-a53-843419'
      export GPARCH="radula_behave_patch 0 gcc glaucus 0001-pure64-for-$ARCH"

      export MARCH=$ARCH

      export LARCH=arm64
      # LCARCH is empty because it uses the regular `defconfig`
      export LCARCH=
      export LIARCH=arch/$LARCH/boot/Image

      export TGT=$ARCH-glaucus-linux-musl
      ;;
    armv6zk | arm | bcm2835)
      export ARCH=armv6zk

      export CARCH=--with-gcc-arch=$ARCH

      export FARCH="-mabi=aapcs-linux -mfloat-abi=hard -march=$ARCH -mtune=arm1176jzf-s -mcpu=arm1176jzf-s -mfpu=vfpv2"

      export GCARCH="--with-arch=$ARCH --with-tune=arm1176jzf-s --with-abi=aapcs-linux --with-fpu=vfpv2 --with-float=hard"
      # Doesn't need a pure64 patch for GCC since this isn't a 64 bit
      # architecture; hence, GPARCH is empty.
      export GPARCH=

      export MARCH=arm

      export LARCH=$MARCH
      # Optimize the linux configuration for the Raspberry Pi 1 Models A, B, B+,
      # the Compute Module, and the Raspberry Pi Zero.
      export LCARCH=bcm2835_
      export LIARCH=arch/$MARCH/boot/zImage

      export TGT=$ARCH-glaucus-linux-musleabihf
      ;;
    i686 | i386 | x86)
      # The i686 seems like the most logical 32-bit x86 architecture to optimize
      # for at this point.
      export ARCH=i686

      export CARCH=--with-gcc-arch=$ARCH

      export FARCH="-march=$ARCH -mtune=generic -mabi=sysv"

      export GCARCH="--with-arch=$ARCH --with-tune=generic"
      export GPARCH=

      # musl only knows i386, so we use that to configure it.
      export MARCH=i386

      # Same goes for the kernel.
      export LARCH=$MARCH
      export LCARCH=${MARCH}_
      export LIARCH=arch/x86/boot/bzImage

      export TGT=$ARCH-glaucus-linux-musl
      ;;
    microblaze | microblazebe | microblazeeb)
      export ARCH=microblaze

      # Empty because there's no -march/--with-arch
      export CARCH=

      # The cpu version was chosen from:
      # https://www.xilinx.com/support/documentation/sw_manuals/xilinx2020_1/ug984-vivado-microblaze-ref.pdf
      # We have to specify that we want the big endian variant of microblaze
      export FARCH='-mhard-float -mcpu=v11.0 -mbig-endian'

      # --with-cpu isn't supported for this arch
      # --with-float isn't supported for this arch as well
      export GCARCH=--with-endian=big
      export GPARCH=

      export MARCH=$ARCH

      export LARCH=$ARCH
      export LCARCH=mmu_
      # The image location needs checking
      export LIARCH=arch/$ARCH/boot/bzImage

      export TGT=$ARCH-glaucus-linux-musl
      ;;
    microblazeel | microblazele)
      export ARCH=microblazeel

      # Empty because there's no -march/--with-arch
      export CARCH=

      # The cpu version was chosen from:
      # https://www.xilinx.com/support/documentation/sw_manuals/xilinx2020_1/ug984-vivado-microblaze-ref.pdf
      # We have to specify that we want the little endian variant of microblaze
      export FARCH='-mhard-float -mcpu=v11.0 -mlittle-endian'

      # --with-cpu isn't supported for this arch
      # --with-float isn't supported for this arch as well
      export GCARCH=--with-endian=little
      export GPARCH=

      export MARCH=microblaze

      export LARCH=$MARCH
      export LCARCH=mmu_
      # The image location needs checking
      export LIARCH=arch/$MARCH/boot/bzImage

      export TGT=$ARCH-glaucus-linux-musl
      ;;
    mips64 | mips64r2 | mips | mips64be | mips64eb)
      export ARCH=mips64

      export CARCH=--with-gcc-arch=${ARCH}r2

      # We have to specify that we want the little endian variant of mips64
      export FARCH="-EB -march=${ARCH}r2 -mabi=64 -mhard-float"

      export GCARCH="--with-endian=big --with-arch=${ARCH}r2 --with-abi=64 --with-float=hard"
      export GPARCH="radula_behave_patch 0 gcc glaucus 0001-pure64-for-$ARCH"

      export MARCH=$ARCH

      export LARCH=mips
      # Another valid options is the "cavium_octeon_" (Don't specify the
      # "loongson3_" here because all loongson devices are little endian).
      export LCARCH=malta_
      # The image location needs checking
      export LIARCH=vmlinux

      export TGT=$ARCH-glaucus-linux-musl
      ;;
    mips64el | mips64le | mips64r2el | mips64elr2)
      export ARCH=mips64el

      export CARCH=--with-gcc-arch=mips64r2

      # We have to specify that we want the little endian variant of mips64
      export FARCH='-EL -march=mips64r2 -mabi=64 -mhard-float'

      export GCARCH='--with-endian=little --with-arch=mips64r2 --with-abi=64 --with-float=hard'
      export GPARCH='radula_behave_patch 0 gcc glaucus 0001-pure64-for-mips64'

      export MARCH=mips64

      export LARCH=mips
      # Other valid options are the "cavium_octeon_" and the "loongson3_"
      export LCARCH=malta_
      # The image location needs checking
      export LIARCH=vmlinux

      export TGT=$ARCH-glaucus-linux-musl
      ;;
    mipsisa64r6 | mips64r6)
      # Using mips64r6 won't work as the "real" arch is mipsisa64r6
      export ARCH=mipsisa64r6

      export CARCH=--with-gcc-arch=mips64r6

      # We have to specify that we want the little endian variant of mips64r6
      export FARCH='-EB -march=mips64r6 -mabi=64 -mhard-float -mnan=2008'

      export GCARCH='--with-endian=big --with-arch=mips64r6 --with-abi=64 --with-float=hard --with-nan=2008'
      export GPARCH='radula_behave_patch 0 gcc glaucus 0001-pure64-for-mips64'

      export MARCH=mips64

      export LARCH=mips
      # The default configuration we're choosing needs checking
      export LCARCH=malta_
      # The image location needs checking
      export LIARCH=vmlinux

      # Using mips64r6 won't work as the "real" arch is mipsisa64r6
      export TGT=$ARCH-glaucus-linux-musl
      ;;
    mipsisa64r6el | mips64r6el | mips64r6le)
      # Using mips64r6el won't work as the "real" arch is mipsisa64r6el
      export ARCH=mipsisa64r6el

      export CARCH=--with-gcc-arch=mips64r6

      # We have to specify that we want the little endian variant of mips64r6
      export FARCH='-EL -march=mips64r6 -mabi=64 -mhard-float -mnan=2008'

      export GCARCH='--with-endian=little --with-arch=mips64r6 --with-abi=64 --with-float=hard --with-nan=2008'
      export GPARCH='radula_behave_patch 0 gcc glaucus 0001-pure64-for-mips64'

      export MARCH=mips64

      export LARCH=mips
      # The default configuration we're choosing needs checking
      export LCARCH=malta_
      # The image location needs checking
      export LIARCH=vmlinux

      # Using mips64r6el won't work as the "real" arch is mipsisa64r6el
      export TGT=$ARCH-glaucus-linux-musl
      ;;
    or1k | openrisc | or1ksim)
      export ARCH=or1k

      # CARCH is empty because there's no -march/--with-arch
      export CARCH=

      # -mboard defaults to ork1sim (which is what we're using), might consider
      # changing it to de0_nano
      export FARCH=-mhard-float

      # There's no such option as --with-float=hard for this arch
      export GCARCH=
      export GPARCH=

      export MARCH=$ARCH

      export LARCH=openrisc
      export LCARCH=${ARCH}sim_
      # The image location needs checking
      export LIARCH=arch/$LARCH/boot/bzImage

      export TGT=$ARCH-glaucus-linux-musl
      ;;
    powerpc | pmac32 | ppc)
      export ARCH=powerpc

      export CARCH=

      export FARCH="-mcpu=$ARCH -msecure-plt"

      export GCARCH="--with-cpu=$ARCH --enable-secureplt --without-long-double-128"
      export GPARCH=

      export MARCH=$ARCH

      export LARCH=$ARCH
      export LCARCH=pmac32_
      export LIARCH=vmlinux

      export TGT=$ARCH-glaucus-linux-musl
      ;;
    powerpc64 | g5 | ppc64 | powerpc64be | powerpc64eb | ppc64be | ppc64eb)
      export ARCH=powerpc64

      export CARCH=

      export FARCH="-mcpu=$ARCH -mabi=elfv2"

      export GCARCH="--with-cpu=$ARCH --with-abi=elfv2"
      export GPARCH="radula_behave_patch 0 gcc glaucus 0001-pure64-for-$ARCH"

      export MARCH=$ARCH

      export LARCH=powerpc
      # If you want to optimize the kernel configuration for the PlayStation 3,
      # you can use `altivec_` for LCARCH (which makes the kernel configure for
      # `altivec_defconfig`) which is also a powerpc64 architecture.
      export LCARCH=g5_
      export LIARCH=vmlinux

      export TGT=$ARCH-glaucus-linux-musl
      ;;
    powerpc64le | powernv | ppc64le)
      export ARCH=powerpc64le

      export CARCH=

      export FARCH="-mcpu=$ARCH -mabi=elfv2"

      export GCARCH="--with-cpu=$ARCH --with-abi=elfv2"
      export GPARCH='radula_behave_patch 0 gcc glaucus 0001-pure64-for-powerpc64'

      export MARCH=powerpc64

      export LARCH=powerpc
      export LCARCH=powernv_
      export LIARCH=vmlinux

      export TGT=$ARCH-glaucus-linux-musl
      ;;
    riscv64 | rv64imafdc | riscv)
      export ARCH=riscv64

      export CARCH=--with-gcc-arch=rv64imafdc

      export FARCH='-mabi=lp64d -march=rv64imafdc -mtune=rocket'

      export GCARCH='--with-arch=rv64imafdc --with-tune=rocket --with-abi=lp64d'
      export GPARCH="radula_behave_patch 0 gcc glaucus 0001-pure64-for-$ARCH"

      export MARCH=$ARCH

      export LARCH=riscv
      # LCARCH is empty because it uses the regular `defconfig`
      export LCARCH=
      export LIARCH=arch/$LARCH/boot/Image

      export TGT=$ARCH-glaucus-linux-musl
      ;;
    s390x | z196 | z15 | s390)
      export ARCH=s390x

      export CARCH=--with-gcc-arch=z196

      # -mhard-dfp is the default on z9-ec and higher (e.g. z196)
      # s390x implies -m64 which in turn implies -mzarch
      # -mlong-double-128 is needed because 64 bits is the default
      export FARCH="-mlong-double-128 -march=z196 -mtune=z15"

      # --enable-decimal-float is the default on z9-ec and higher (e.g. z196)
      # s390x implies -m64 which in turn implies --with-zarch
      # --with-long-double-128 is needed because 64 bits is the default
      export GCARCH="--with-arch=z196 --with-tune=z15 --with-long-double-128"
      export GPARCH="radula_behave_patch 0 gcc glaucus 0001-pure64-for-$ARCH"

      export MARCH=$ARCH

      export LARCH=s390
      # LCARCH is empty because it uses the regular `defconfig`
      export LCARCH=
      export LIARCH=arch/$LARCH/boot/bzImage

      export TGT=$ARCH-glaucus-linux-musl
      ;;
    x86-64 | x86_64)
      export ARCH=x86-64

      export CARCH=--with-gcc-arch=$ARCH

      export FARCH="-march=$ARCH -mtune=generic -mabi=sysv"

      export GCARCH="--with-arch=$ARCH --with-tune=generic"
      export GPARCH="radula_behave_patch 0 gcc glaucus 0001-pure64-for-$ARCH"

      export MARCH=x86_64

      export LARCH=$MARCH
      export LCARCH=${MARCH}_
      export LIARCH=arch/x86/boot/bzImage

