#
# Neutralize
#

set -e
umask 022
unalias -a

#
# Disable Unicode
#

LANG=C
LC_ALL=C

#
# Source Configuration File and Set Default Variables
#

if [ -f /etc/radula.conf ]; then
  . /etc/radula.conf
elif [ -f radula.conf ]; then
  # Don't use `. radula.conf` because it won't work
  . ./radula.conf
else
  ccache=yes
  check=no
  genome=x86-64
  parallel=yes
  species=atlanticus
fi

#
# IO Functions
#

# Use `exit 1` instead of radula_close when you don't want to print anything
radula_close() {
  printf '\033[0;31m--\033[0m %b\n' "$1" >&2

  exit 1
}

radula_open() {
  printf "\033[0;34m~~\033[0m "
  if [ $# -gt 1 ]; then
    printf "\033[1;${1}m$2\033[0m "

    shift 2

    # The extra trailing space and printf are necessary
    printf '%b ' "$@"
    printf '\n'
  else
    printf '%b\n' "$1"
  fi
}

