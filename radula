#
# Common Behavior Variable Functions
#

# For custom ccache directories (or if host was neither Arch nor Fedora, the
# user has to specify them in /etc/radula.conf using the `CCCH` variable (along
# with ccache=yes beforehand).
rad_behave_ccache_variables() {
  CCCH=${1:-/usr/lib/ccache/bin:/usr/lib64/ccache}
  export PATH=$CCCH:$PATH
}

rad_behave_pkg_config_variables() {
  # pkgconf and pkg-config don't respect the provided sysroot (it doesn't get
  # automatically prefixed to PATH and LIBDIR)
  export PKG_CONFIG_PATH=$1/usr/lib/pkgconfig:$1/usr/share/pkgconfig
  export PKG_CONFIG_LIBDIR=$1/usr/lib/pkgconfig:$1/usr/share/pkgconfig
  # The trailing forward slash is important (envenomate on a glaucus system)
  export PKG_CONFIG_SYSROOT_DIR=$1/
  export PKG_CONFIG_SYSTEM_INCLUDE_PATH=$1/usr/include
  export PKG_CONFIG_SYSTEM_LIBRARY_PATH=$1/usr/lib
}

# teeth are radula's tools
rad_behave_teeth_variables() {
  if [ $sleep = no ]; then
    export AUTORECONF='autoreconf -fvis'
    export CHMOD='chmod -Rv'
    export CHOWN='chown -Rv'
    export LN='ln -fnsv'

    if [ $parallel = yes ]; then
      export MAKE="make -j V=1"
    else
      export MAKE='make -j1 V=1'
    fi

    # Full path to not overlap with the install() function in .ceras files
    export MKDIR='/usr/bin/install -dv'
    export MV='mv -v'
    export RM='rm -frv'
    export RSYNC='rsync -vaHAXSx'
    export UMOUNT='umount -fqRv'
  else
    export AUTORECONF='autoreconf -fis'
    export CHMOD='chmod -R'
    export CHOWN='chown -R'
    export LN='ln -fns'

    if [ $parallel = yes ]; then
      export MAKE="make -j"
    else
      export MAKE='make -j1'
    fi

    export MKDIR='/usr/bin/install -d'
    export MV=mv
    export RM='rm -fr'
    export RSYNC='rsync -aHAXSx'
    export UMOUNT='umount -fqR'
  fi
}

#
# Common Behavior Action Functions
#

rad_behave_check() {
  . $CERD/$1/ceras

  if [ ! -d $SRCD/$nom ]; then
    rad_behave_fetch $(basename $url) || rad_close "ceras $nom: fetch exited with status $?"
  # In the case of a directory existing in $SRCD, and only if it's not a git
  # repository, then verify the tarball inside (if the tarball was previously
  # extracted, then verifying it won't matter much because the extracted
  # contents could've been tampered with (which is extremely unlikely) , and
  # this would require a reextraction in all cases which would slow down build
  # times by a bit (and not by a whole much because we're using zstd). The only
  # benefit that might come from reverifying an extracted tarball is this would
  # be if the tarball was already broken, but then again it was verified before
  # so how could that happen?
  elif [ $ver != git ]; then
    rad_behave_verify $(basename $url) || rad_close "ceras $nom: verify exited with status $?"
  fi
}

rad_behave_construct() {
  . $CERD/$2/ceras
  . $CERD/$nom/$1.ceras

  prepare || rad_close "ceras $nom: prepare exited with status $?"
  configure || rad_close "ceras $nom: configure exited with status $?"
  build || rad_close "ceras $nom: build exited with status $?"
  install || rad_close "ceras $nom: install exited with status $?"
}

rad_behave_fetch() {
  if [ $ver = git ]; then
    if [ $sleep = no ]; then
      git clone $url $SRCD/$nom
      git -C $SRCD/$nom checkout $cmt
    else
      git clone -q $url $SRCD/$nom
      git -C $SRCD/$nom checkout -q $cmt
    fi
  else
    $MKDIR $SRCD/$nom

    if [ $sleep = no ]; then
      curl -Lo $SRCD/$nom/$1 $url
    else
      curl -Lso $SRCD/$nom/$1 $url
    fi

    rad_behave_verify $1 || rad_close "ceras $nom: verify exited with status $?"

    if [ $sleep = no ]; then
      tar xvf $SRCD/$nom/$1 -C $SRCD/$nom
    else
      tar xf $SRCD/$nom/$1 -C $SRCD/$nom
    fi
  fi
}

rad_behave_gnu() {
  $RSYNC $CERD/binutils/config.$1 $2
}

rad_behave_patch() {
  if [ $sleep = no ]; then
    patch -p$1 -i $CERD/$2/patches/$3/$4.patch
  else
    patch -p$1 -si $CERD/$2/patches/$3/$4.patch
  fi
}

rad_behave_verify() {
  if [ $sleep = no ]; then
    printf "%s" "$sum $SRCD/$nom/$1" | sha512sum -c
  else
    printf "%s" "$sum $SRCD/$nom/$1" | sha512sum -c > /dev/null
  fi
}

#
# Bootstrap Behavior Functions
#

rad_behave_bootstrap() {
  rad_behave_bootstrap_${1}_variables
  rad_behave_bootstrap_${1}_check
  rad_behave_bootstrap_${1}_prepare

  rad_behave_bootstrap_${1}_construct

  [ $1 = toolchain ] && rad_behave_bootstrap_${1}_backup
}

# Architecture related variables explained (for rad_behave_bootstrap_arch):
#
# ARCH stands for the technically correct architecture (except for ones with a
# dash in them '-', then they get turned to underscores '_').
#
# CARCH stands for Cerata ARCH, which means options/flags that are related to a
# certain architecture and are passed in that ceras's configure function mostly
# (this includes all cerata with the exception of `gcc` as that has its own
# variable GCARCH).
#
# FARCH stands for Flags ARCH, which means options/flags that are related to a
# certain architecture and are passed in rad_behave_bootstrap_flags.
#
# GCARCH stands for Gcc Configuration ARCH, which means options/flags that are
# related to a certain architecture and are passed the `gcc` ceras configure
# function (In this regard, CARCH stands for cerata other than `gcc`).
#
# GPARCH stands for Gcc Patch ARCH, which refers to the architecture of the
# pure64 patch by glaucus applied to the `gcc` sources in the prepare function.
#
# MARCH stands for Musl ARCH, which refers to the closest architecture
# recognized by `musl`.
#
# LARCH stands for Linux ARCH, which refers to the closest architecture
# recognized by `linux`.
#
# LCARCH stands for Linux Configuration ARCH, which refers to the closest device
# with a similar architecture that's used to configure the kernel sources.
#
# LIARCH stands for Linux Image ARCH, which refers to the directory where
# `linux` stores its image file after it has been built.
rad_behave_bootstrap_arch_variables() {
  case $genome in
    aarch64 | armv8-a | arm64)
      export ARCH=aarch64

      export CARCH=--with-gcc-arch=armv8-a

      export FARCH='-mabi=lp64 -mfix-cortex-a53-835769 -mfix-cortex-a53-843419 -march=armv8-a -mtune=generic'

      export GCARCH='--with-arch=armv8-a --with-abi=lp64 --enable-fix-cortex-a53-835769 --enable-fix-cortex-a53-843419'
      export GPARCH="rad_behave_patch 0 gcc glaucus 0001-pure64-for-$ARCH"

      export MARCH=$ARCH

      export LARCH=arm64
      # LCARCH is empty because it uses the regular `defconfig`
      export LCARCH=
      export LIARCH=arch/$LARCH/boot/Image

      export TGT=$ARCH-glaucus-linux-musl
      ;;
    armv6zk | arm | bcm2835)
      export ARCH=armv6zk

      export CARCH=

      export FARCH="-mabi=aapcs-linux -march=$ARCH -mtune=arm1176jzf-s -mcpu=arm1176jzf-s -mfpu=vfpv2 -mfloat-abi=hard"

      export GCARCH="--with-arch=$ARCH --with-tune=arm1176jzf-s --with-abi=aapcs-linux --with-fpu=vfpv2 --with-float=hard"
      # Doesn't need a pure64 patch for GCC since this isn't a 64 bit
      # architecture; hence, GPARCH is empty.
      export GPARCH=

      export MARCH=arm

      export LARCH=$MARCH
      # Optimize the linux configuration for the Raspberry Pi 1 Models A, B, B+,
      # the Compute Module, and the Raspberry Pi Zero.
      export LCARCH=bcm2835_
      export LIARCH=arch/$MARCH/boot/zImage

      export TGT=$ARCH-glaucus-linux-musleabihf
      ;;
    i686 | i386 | x86)
      # The i686 seems like the most logical 32-bit x86 architecture to optimize
      # for at this point.
      export ARCH=i686

      export CARCH=--with-gcc-arch=$ARCH

      export FARCH="-march=$ARCH -mtune=generic -mabi=sysv"

      export GCARCH="--with-arch=$ARCH --with-tune=generic"
      export GPARCH=

      # musl only knows i386, so we use that to configure it.
      export MARCH=i386

      # Same goes for the kernel.
      export LARCH=$MARCH
      export LCARCH=${MARCH}_
      export LIARCH=arch/x86/boot/bzImage

      export TGT=$ARCH-glaucus-linux-musl
      ;;
    powerpc | pmac32 | ppc)
      export ARCH=powerpc

      export CARCH=

      export FARCH="-mcpu=$ARCH -msecure-plt"

      export GCARCH="--with-cpu=$ARCH --enable-secureplt --without-long-double-128"
      export GPARCH=

      export MARCH=$ARCH

      export LARCH=$ARCH
      export LCARCH=pmac32_
      export LIARCH=vmlinux

      export TGT=$ARCH-glaucus-linux-musl
      ;;
    powerpc64 | g5 | ppc64)
      export ARCH=powerpc64

      export CARCH=

      export FARCH="-mcpu=$ARCH -mabi=elfv2"

      export GCARCH="--with-cpu=$ARCH --with-abi=elfv2"
      export GPARCH="rad_behave_patch 0 gcc glaucus 0001-pure64-for-$ARCH"

      export MARCH=$ARCH

      export LARCH=powerpc
      # If you want to optimize the kernel configuration for the PlayStation 3,
      # you can use `altivec_` for LCARCH (which makes the kernel configure for
      # `altivec_defconfig`) which is also a powerpc64 architecture.
      export LCARCH=g5_
      export LIARCH=vmlinux

      export TGT=$ARCH-glaucus-linux-musl
      ;;
    powerpc64le | powernv | ppc64le)
      export ARCH=powerpc64le

      export CARCH=

      export FARCH="-mcpu=$ARCH -mabi=elfv2"

      export GCARCH="--with-cpu=$ARCH --with-abi=elfv2"
      export GPARCH="rad_behave_patch 0 gcc glaucus 0001-pure64-for-powerpc64"

      export MARCH=powerpc64

      export LARCH=powerpc
      export LCARCH=powernv_
      export LIARCH=vmlinux

      export TGT=$ARCH-glaucus-linux-musl
      ;;
    riscv64 | rv64imafdc | riscv)
      export ARCH=riscv64

      export CARCH=--with-gcc-arch=rv64imafdc

      export FARCH='-mabi=lp64d -march=rv64imafdc -mtune=rocket'

      export GCARCH='--with-arch=rv64imafdc --with-tune=rocket --with-abi=lp64d'
      export GPARCH="rad_behave_patch 0 gcc glaucus 0001-pure64-for-$ARCH"

      export MARCH=$ARCH

      export LARCH=riscv
      export LCARCH=
      export LIARCH=arch/$LARCH/boot/Image

      export TGT=$ARCH-glaucus-linux-musl
      ;;
    x86-64 | x86_64)
      export ARCH=x86-64

      export CARCH=--with-gcc-arch=$ARCH

      export FARCH="-march=$ARCH -mtune=generic -mabi=sysv"

      export GCARCH="--with-arch=$ARCH --with-tune=generic"
      export GPARCH="rad_behave_patch 0 gcc glaucus 0001-pure64-for-$ARCH"

      export MARCH=x86_64

      export LARCH=$MARCH
      export LCARCH=${MARCH}_
      export LIARCH=arch/x86/boot/bzImage

      export TGT=$MARCH-glaucus-linux-musl
      ;;
    *)
      $0 l g
      exit 1
      ;;
  esac
}

