set -e
umask 022

# Define the default variables
behavior=envenomate
sleep=0

# Define the default location for cerata (testing atm)
CERD=$PWD/../cerata

# Standard output function
# Opens the radula (mouth)
rad_open() {
  [ $sleep = 0 ] && printf "\033[0;34m~~\033[0m $1\n" || printf "$1\n"
}

# Standard error function
# Closes the radula (mouth)
rad_close() {
  [ $sleep = 0 ] && printf "\033[0;31m~~\033[0m $1\n" || printf "$1\n"
  exit 1
}

# Information functions
rad_license() {
  rad_open 'Copyright (c) 2018-2020, Firas Khalil Khana'
  rad_open 'Distributed under the terms of the ISC License'
}

rad_version() {
  rad_license

  rad_open
  rad_open "$0 version 0.3"
}

# require will be moved to behave bootstrap options
rad_help() {
  rad_version

  rad_open
  rad_open 'Usage:'
  rad_open "\t$0 (Flags)"
  rad_open
  rad_open 'Flags:'
  rad_open '\tb, -b, --behave \tPerform any of the following behaviors:'
  rad_open '\t                \tbootstrap, envenomate (default)'
  rad_open
  rad_open '\tg, -g, --genome \tDisplay current genome'
  rad_open '\th, -h, --help   \tDisplay this help message'
  rad_open '\tl, -l, --list   \tList available genomes and species'
  rad_open '\tq, -q, --quiet  \tDo not prefix output with ~~'
  rad_open '\t       --sleep  \tSame as --quiet'
  rad_open
  rad_open '\tr, -r, --require\tDisplay bootstrap requirements'
  rad_open '\ts, -s, --species\tDisplay current species'
  rad_open '\tv, -v, --version\tDisplay version number'
}

rad_behave_help() {
  rad_version

  rad_open
  rad_open 'Usage:'
  rad_open "\t$0 b (Options)"
  rad_open
  rad_open 'Options:'
  rad_open "\tb, bootstrap \tPerform bootstrap behavior"
  rad_open "\te, envenomate\tPerform envenomate behavior (default)"
}

rad_behave_bootstrap_help() {
  rad_version

  rad_open
  rad_open 'Usage:'
  rad_open "\t$0 b b (Options)"
  rad_open
  rad_open 'Options:'
  rad_open "\tc, chroot   \tBootstrap a chroot environment"
  rad_open "\tt, toolchain\tBootstrap a cross-compiler toolchain"
  rad_open "\tx, cross    \tBootstrap a cross-compiled glaucus system (default)"
}

rad_behave_envenomate_help() {
  rad_version

  rad_open
  rad_open 'Usage:'
  rad_open "\t$0 b e (Options) [Cerata]"
  rad_open
  rad_open 'Options:'
  rad_open "\tn, nom, name                     \tDisplay ceras's name"
  rad_open "\tv, ver, version                  \tDisplay ceras's version"
  rad_open "\tu, url, source                   \tDisplay ceras's source"
  rad_open "\ts, sum, checksum, sha512sum      \tDisplay ceras's sha512sum"
  rad_open "\ty, cys, cyst, cysts              \tDisplay ceras's cyst(s)"
  rad_open "\tc, cnt, concentrate, concentrates\tDisplay ceras's concentrate(s)"
  rad_open "\tl, lic, license, licenses        \tDisplay ceras's license(s)"
}

# Action functions
