#
# Common Behavior Functions
#

rad_behave_verify() {
  if [ $sleep -eq 0 ]; then
    printf "$sum $SRCD/$nom/$1" | sha512sum -c
  else
    printf "$sum $SRCD/$nom/$1" | sha512sum -c > /dev/null
  fi
}

rad_behave_fetch() {
  if [ $ver = git ]; then
    [ $sleep -eq 0 ] && git clone $url $SRCD/$nom || git clone -q $url $SRCD/$nom
  else
    $MKDIR $SRCD/$nom

    [ $sleep -eq 0 ] && curl -Lo $SRCD/$nom/$1 $url || curl -Lso $SRCD/$nom/$1 $url

    rad_behave_verify $1 || rad_close "ceras $nom: verify exited with status $?"

    [ $sleep -eq 0 ] && tar xvf $SRCD/$nom/$1 -C $SRCD/$nom || tar xf $SRCD/$nom/$l -C $SRCD/$nom
  fi
}

rad_behave_check() {
  . $CERD/$1/ceras

  if [ ! -d $SRCD/$nom ]; then
    rad_behave_fetch $(basename $url) || rad_close "ceras $nom: fetch exited with status $?"
  # In the case of a directory existing in $SRCD, and only if it's not a git
  # repository, then verify the tarball inside (if the tarball was previously
  # extracted, then verifying it won't matter much because the extracted
  # contents could've been tampered with (which is extremely unlikely) , and
  # this would require a reextraction in all cases which would slow down build
  # times by a bit (and not by a whole much because we're using zstd). The only
  # benefit that might come from reverifying an extracted tarball is this would
  # be if the tarball was already broken, but then again it was verified before
  # so how could that happen?
  elif [ $ver != git ]; then
    rad_behave_verify $(basename $url) || rad_close "ceras $nom: verify exited with status $?"
  fi
}

rad_behave_construct() {
  . $CERD/$2/ceras
  . $CERD/$nom/$1.ceras

  prepare || rad_close "ceras $nom: prepare exited with status $?"
  configure || rad_close "ceras $nom: configure exited with status $?"
  build || rad_close "ceras $nom: build exited with status $?"
  install || rad_close "ceras $nom: install exited with status $?"
}

rad_behave_envenomate() {
  $MKDIR $XCER/$1/sac
  $MKDIR $XCER/$1/venom

  rad_behave_construct cross $1

  $RSYNC $XCER/$1/sac/ $CRSD
}

rad_behave_gnu() {
  $RSYNC $CERD/binutils/config.$1 $2
}

rad_behave_patch() {
  [ $sleep -eq 0 ] && patch -p$1 -i $CERD/$2/patches/$3/$4.patch || patch -p$1 -si $CERD/$2/patches/$3/$4.patch
}

