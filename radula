#
# Main
#

# Tip: prefix or postfix your options with the letter `q` to correctly silence
# radula.
#
# Currently the flag "require" wrongly turns the quiet signal on since the word
# "require" has a "q" in it. This needs to be fixed.
case "$@" in
  *q* | *-q* | *--quiet* | *--sleep*)
    sleep=1
    ;;
esac

# rad l q [g, s] doesn't work since list expects genome or species
while [ $# -ge 0 ]; do
  case $1 in
    '')
      rad_help
      exit 1
      ;;
    b | -b | --behave)
      case $2 in
        b | bootstrap | r | reproduce)
          case $3 in
            c | clean)
              rad_behave_bootstrap_variables

              rad_behave_bootstrap_toolchain_variables

              rad_behave_bootstrap_cross_variables

              rad_behave_bootstrap_clean
              ;;
            d | distclean)
              rad_behave_bootstrap_variables

              rad_behave_bootstrap_toolchain_variables

              rad_behave_bootstrap_cross_variables

              rad_behave_bootstrap_distclean
              ;;
            h | -h | --help)
              rad_behave_bootstrap_help
              ;;
            i | img | image)
              rad_behave_bootstrap_variables

              if [ $(id -u) -eq 0 ]; then
                rad_behave_bootstrap_cross_img $GLAD/glaucus.img 128M $(losetup -f) /mnt/glaucus
              else
                rad_close 'Please run this script as root!'
              fi
              ;;
            l | list)
              rad_version

              rad_open
              rad_open 'Genomes (Architectures):'
              rad_open '\taarch64,     armv8-a,    arm64'
              rad_open '\tarmv6zk,     arm,        bcm2835'
              rad_open '\ti686,        i386,       x86'
              rad_open '\tpowerpc,     pmac32,     ppc'
              rad_open '\tpowerpc64,   g5,         ppc64'
              rad_open '\tpowerpc64le, powernv,    ppc64le'
              rad_open '\triscv64,     rv64imafdc, riscv'
              rad_open '\tx86-64,      x86_64'
              rad_open
              rad_open 'Species (Flags):'
              rad_open '\talbino,     libre'
              rad_open '\tatlanticus, performance'
              rad_open '\tbennettae,  size'
              rad_open '\tmarginatus, sane'
              rad_open '\tthompsoni,  radiology'
              exit 0
              ;;
            r | require)
              rad_behave_bootstrap_require
              ;;
            s | release)
              rad_behave_bootstrap_variables

              rad_behave_bootstrap_toolchain_release /tmp/toolchain
              ;;
            t | toolchain)
              if [ $sleep = no ]; then
                $0 b b r
              else
                $0 q b b r
              fi

              rad_open
              rad_open "Bootstrapping an $genome cross-compiler toolchain targetting musl libc..."

              rad_behave_bootstrap_variables

              # Only for the toolchain as we're relying on the host's ccache
              [ $ccache = yes ] && rad_behave_ccache_variables $CCCH

              rad_behave_bootstrap_initialize

              rad_behave_bootstrap_clean

              # No rad_behave_bootstrap_flags optimizations for the toolchain
              rad_behave_bootstrap_arch_variables

              rad_behave_bootstrap toolchain > $LOGD/toolchain.log || {
                rad_close "Failed to boostrap an $genome cross-compiler toolchain targetting musl libc."
              }

              rad_open
              rad_open "Successfully bootstrapped an $genome cross-compiler toolchain targetting musl libc!"
              ;;
            x | cross)
              if [ $sleep = no ]; then
                $0 b b r
              else
                $0 q b b r
              fi

              rad_open
              rad_open "Bootstrapping an $genome cross-compiled glaucus $species system..."

              rad_behave_bootstrap_variables

              rad_behave_pkg_config_variables $CRSD

              rad_behave_bootstrap_arch_variables
              rad_behave_bootstrap_flags_variables

              rad_behave_bootstrap cross > $LOGD/cross.log || {
                rad_close "Failed to boostrap an $genome cross-compiled glaucus $species system."
              }

              rad_open
              rad_open "Successfully bootstrapped an $genome cross-compiled glaucus $species system!"
              ;;
            *)
              rad_behave_bootstrap_help
              exit 1
              ;;
          esac
          ;;
        e | envenomate)
          rad_behave_envenomate_help
          exit 0
          ;;
        h | -h | --help)
          rad_behave_help
          exit 0
          ;;
        i | binary)
          rad_behave_help
          exit 0
          ;;
        *)
          rad_behave_help
          exit 1
          ;;
      esac
      exit 0
      ;;
    c | -c | --ceras)
      # Don't check for the directory $CERD/$4 alone because when $4 is
      # empty it'll resolve to $CERD which does exist and will cause radula
      # to fail.
      if [ -f $CERD/$3/ceras ]; then
        . $CERD/$3/ceras

        case $2 in
          n | nom | name)
            rad_open "Name:        \t$nom"
            ;;
          v | ver | version)
            rad_open "Version:     \t$ver"
            ;;
          u | url | source)
            rad_open "Source:      \t$url"
            ;;
          s | sum | checksum | sha512sum)
            rad_open "sha512sum:   \t$sum"
            ;;
          y | cys | cyst | cysts)
            cys_len=$(printf "$cys" | wc -w)
            if [ $cys_len -gt 1 ]; then
              rad_open "Cysts:       \t$(printf "$cys" | sed 's/ /, /g')"
            elif [ $cys_len -eq 1 ]; then
              rad_open "Cyst:        \t$cys"
            else
              rad_open 'Cysts:       \t~~'
            fi
            ;;
          c | cnt | concentrate | concentrates)
            cnt_len=$(printf "$cnt" | wc -w)
            if [ $cnt_len -gt 1 ]; then
              rad_open "Concentrates:\t$(printf "$cnt" | sed 's/ /, /g')"
            elif [ $cnt_len -eq 1 ]; then
              rad_open "Concentrate: \t$cnt"
            else
              rad_open 'Concentrates:\t~~'
            fi
            ;;
          l | lic | license | licenses)
            lic_len=$(printf "$lic" | wc -w)
            if [ $lic_len -gt 1 ]; then
              rad_open "Licenses:    \t$(printf "$lic" | tr '\n' ' ' | sed 's/ /, /g')"
            elif [ $lic_len -eq 1 ]; then
              rad_open "License:     \t$lic"
            else
              rad_open 'Licenses:    \t~~'
            fi
            ;;
          *)
            rad_ceras_help
            exit 1
            ;;
        esac

      elif [ ! -z $2 ] && [ -d $CERD/$2 ]; then
        . $CERD/$2/ceras

        for i in n v u s y c l; do
          if [ $sleep = no ]; then
            $0 c $i $2
          else
            $0 q c $i $2
          fi
        done
      else
        rad_ceras_help
        case $2 in
          h | -h | --help)
            exit 0
            ;;
        esac
        exit 1
      fi
      exit 0
      ;;
    g | -g | --genome)
      rad_open $genome
      exit 0
      ;;
    h | -h | --help)
      rad_help
      exit 0
      ;;
    s | -s | --species)
      rad_open $species
      exit 0
      ;;
    v | -v | --version)
      rad_version
      exit 0
      ;;
  esac

  shift
done
