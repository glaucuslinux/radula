rad_behave_bootstrap_stage_cross_configure() {
  # Might default to leaving the fstab empty or with comments indicating what to
  # put as values, or just multiple commented entries and the user uncomments
  # what he/she wants. One shouldn't forget that the image function
  # rad_behave_bootstrap_stage_cross_img generates an ext4 img, so ext4 should
  # stay the default.
  printf '/dev/sda1 / ext4 defaults 0 1\n' > $CRSD/etc/fstab

  # glaucus's iconic blue coloured shell prompt
  printf 'export PS1="[\033[0;44m\u@\h\033[0m:\033[1m\w\033[0m]$ "
  export HISTFILE=$HOME/.ksh_history\n' > $CRSD/etc/profile

  # 'fifo's can be copied, rsynced and tarred, but they can't be checksummed and
  # they can't be used with fakeroot because they'll become regular files;
  # hence, why we are creating them manually upon completion.
  mkfifo -m 0600 $CRSD/etc/s6/run-image/service/s6-linux-init-shutdownd/fifo
  mkfifo -m 0600 $CRSD/etc/s6/run-image/service/s6-svscan-log/fifo

  # Alphabetically ordered list of available shells. mksh will be replaced by
  # oksh in the future. rksh is just a symlink to ksh (ksh -r, or restricted ksh
  # which I think is obsolete now but useful to have).
  printf '/usr/bin/dash
  /usr/bin/ksh
  /usr/bin/mksh
  /usr/bin/rksh
  /usr/bin/sh\n' > $CRSD/etc/shells
}

rad_behave_bootstrap_stage_cross_strip() {
  # Delete empty directories in etc that we have no use of
  find $CRSD/etc -type d -empty -delete

  # Clean the tmp directory in case it got populated during cross-compilation
  # (it'll probably be empty since we're cross compiling, but in the case of
  # compilation inside a chroot, it might get full).
  $RM $CRSD/tmp/*

  # Stripping
  find $CRSD/usr -name *.a -type f -exec strip -gv {} \;
  find $CRSD/usr \( -name *.so* -a ! -name *dbg \) -type f -exec strip \
    --strip-unneeded -v {} \;
  find $CRSD/usr -type f -exec strip -sv {} \;
  # Delete unneeded libarchive .la files
  find $CRSD/usr -name *.la -delete

  # Remove charset.alias for musl
  $RM $CRSD/usr/lib/charset.alias
}

