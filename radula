# Source the configuration file in /etc/radula.conf
# Will soon be replaced with /etc/radula.conf (No forward slash for testing atm)
. etc/radula.conf

# Catch the quiet signal wherever it was.
# Currently the flag "require" wrongly turns the quiet signal on since the word
# "require" has a "q" in it. This needs to be fixed.
case "$@" in
  *q* | *-q* | *--quiet* | *--sleep*)
    sleep=1
    ;;
esac

# Our basic and portable argument parser
# Sets basic behavior variables and prints information only
# rad l q [g, s] doesn't work since list expects genome or species
while [ $# -ge 0 ]; do
  case $1 in
    # Don't call $0 b e just to exit with behave envenomate help message,
    # instead output that help message directly and let the user think radula is
    # operating in b e mode by default.
    '')
      rad_behave_envenomate_help
      exit 1
      ;;
    b | -b | --behave)
      case $2 in
        b | bootstrap)
          case $3 in
            r | require)
              rad_behave_bootstrap_require
              ;;
            c | chroot)
              [ $sleep -eq 0 ] && $0 b b r || $0 q b b r

              rad_open
              rad_open "Bootstrapping an $genome cross-compiled chroot environment..."

              rad_behave_bootstrap_arch
              rad_behave_bootstrap_flags

              rad_behave_bootstrap_stage_chroot
              ;;
            t | toolchain)
              [ $sleep -eq 0 ] && $0 b b r || $0 q b b r

              rad_open
              rad_open "Bootstrapping an $genome cross-compiler toolchain targetting musl libc..."

              rad_behave_bootstrap_arch

              rad_behave_bootstrap_stage_toolchain
              ;;
            x | cross)
              [ $sleep -eq 0 ] && $0 b b r || $0 q b b r

              rad_open
              rad_open "Bootstrapping an $genome cross-compiled glaucus $species system..."

              rad_behave_bootstrap_arch
              rad_behave_bootstrap_flags

              rad_behave_bootstrap_stage_cross
              ;;
            *)
              rad_behave_bootstrap_help
              exit 1
              ;;
          esac
          ;;
        e | envenomate)
          # Don't check for the directory $CERD/$4 alone because when $4 is
          # empty it'll resolve to $CERD which does exist and will cause radula
          # to fail.
          if [ -f $CERD/$4/ceras ]; then
            . $CERD/$4/ceras

            case $3 in
              n | nom | name)
                rad_open "Name:        \t$nom"
                ;;
              v | ver | version)
                rad_open "Version:     \t$ver"
                ;;
              u | url | source)
                rad_open "Source:      \t$url"
                ;;
              s | sum | checksum | sha512sum)
                rad_open "sha512sum:   \t$sum"
                ;;
              y | cys | cyst | cysts)
                cys_len=$(printf "$cys" | wc -w)
                if [ $cys_len -gt 1 ]; then
                  rad_open "Cysts:       \t$(printf "$cys" | sed 's/ /, /g')"
                elif [ $cys_len -eq 1 ]; then
                  rad_open "Cyst:        \t$cys"
                else
                  rad_open 'Cyst:        \t~~'
                fi
                ;;
              c | cnt | concentrate | concentrates)
                cnt_len=$(printf "$cnt" | wc -w)
                if [ $cnt_len -gt 1 ]; then
                  rad_open "Concentrates:\t$(printf "$cnt" | sed 's/ /, /g')"
                elif [ $cnt_len -eq 1 ]; then
                  rad_open "Concentrate: \t$cnt"
                else
                  rad_open 'Concentrate: \t~~'
                fi
                ;;
              l | lic | license | licenses)
                lic_len=$(printf "$lic" | wc -w)
                if [ $lic_len -gt 1 ]; then
                  rad_open "Licenses:    \t$(printf "$lic" | tr '\n' ' ' | sed 's/ /, /g')"
                elif [ $lic_len -eq 1 ]; then
                  rad_open "License:     \t$lic"
                else
                  rad_open 'License:     \t~~'
                fi
                ;;
              '' | *)
                rad_behave_envenomate_help
                exit 1
                ;;
            esac

          elif [ -d $CERD/$3 ]; then
            . $CERD/$3/ceras

            for i in n v u s y c l; do
              [ $sleep -eq 0 ] && $0 b e $i $3 || $0 q b e $i $3
            done
          else
            rad_behave_envenomate_help
            exit 1
          fi
          ;;
        *)
          rad_behave_help
          exit 1
          ;;
      esac
      exit 0
      ;;
    bb | -bb)
      shift
      [ $sleep -eq 0 ] && $0 b b $@ || $0 q b b $@
      exit 0
      ;;
    be | -be)
      shift
      [ $sleep -eq 0 ] && $0 b e $@ || $0 q b e $@
      exit 0
      ;;
    g | -g | --genome)
      rad_open $genome
      exit 0
      ;;
    h | -h | --help)
      rad_help
      exit 0
      ;;
    l | -l | --list)
      case $2 in
        '')
          [ $sleep -eq 0 ] && $0 l g || $0 q l g

          rad_open

          [ $sleep -eq 0 ] && $0 l s || $0 q l s
          ;;
        g | genome)
          rad_open 'Genomes (Archs):'
          rad_open '\taarch64,          armv8-a,    arm64'
          rad_open '\tarmv6zk,          arm,        bcm2835'
          rad_open '\ti686,             i386,       x86'
          rad_open '\tpowerpc,          pmac32,     ppc'
          rad_open '\tpowerpc64,        g5,         ppc64'
          rad_open '\tpowerpc64le,      powernv,    ppc64le'
          rad_open '\triscv64,          rv64imafdc, riscv'
          rad_open '\tx86-64 (default), x86_64'
          ;;
        s | species)
          rad_open 'Species (Flags):'
          rad_open '\talbino,               libre'
          rad_open '\tatlanticus (default), performance'
          rad_open '\tbennettae,            size'
          rad_open '\tmarginatus,           sane'
          rad_open '\tthompsoni,            radiology'
          ;;
        *)
          rad_close 'Valid list options are: g, genome, s and species'
          ;;
      esac

      exit 0
      ;;
    q | -q | --quiet | --sleep)
      sleep=1
      ;;
    s | -s | --species)
      rad_open $species
      exit 0
      ;;
    v | -v | --version)
      rad_version
      exit 0
      ;;
    *)
      [ $sleep -eq 0 ] && $0 b e $@ || $0 q b e $@
      exit 0
      ;;
  esac

  shift
done
