  rad_open
  rad_open 'Usage:'
  rad_open "\t$0 b b (Options)"
  rad_open
  rad_open 'Options:'
  rad_open '\tr, require  \tCheck if the host system has all required packages'
  rad_open
  rad_open '\tc, chroot   \tBootstrap a cross compiled chroot environment'
  rad_open '\tt, toolchain\tBootstrap a cross compiler toolchain'
  rad_open '\tx, cross    \tBootstrap a cross compiled glaucus system (default)'
