set -e
umask 022
unalias -a

# Disable unicode
LANG=C
LC_ALL=C

#
# Default Variables
#

bootstrap=no
ccache=yes
genome=x86-64
init=finit
kernel=yes
parallel=yes
sleep=no
species=atlanticus

#
# Source Configuration File
#

if [ -f /etc/radula.conf ]; then
  . /etc/radula.conf
elif [ -f /etc/rad.conf ]; then
  . /etc/rad.conf
elif [ -f radula.conf ]; then
  . ./radula.conf
elif [ -f rad.conf ]; then
  . ./rad.conf
fi

#
# Default Directories
#

if [ $bootstrap = no ]; then
  GLAD=/usr
else
  GLAD=$PWD/..
fi

CERD=$GLAD/cerata

#
# IO Functions
#

# Use `exit 1` instead of rad_close when you don't want to print anything
rad_close() {
  [ $sleep = no ] && printf "\033[0;31m--\033[0m " >&2
  printf "%b\n" "$1" >&2

  exit 1
}

rad_open() {
  [ $sleep = no ] && printf "\033[0;34m~~\033[0m "
  printf "%b\n" "$1"
}

